;; G2 disk-loaded script: this file is read by TurmericResourceLoader
;; when GDScript calls load("res://scripts/hello.tur"), then routed
;; through TurmericScript::_reload.

(defn _ready []
  (godot-println "[hello.tur] _ready: I was loaded from disk via the ResourceFormatLoader"))

(defn add [a : int b : int]
  (+ a b))
